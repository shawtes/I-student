{
  "name": "i-student",
  "version": "1.0.0",
  "description": "AI-powered student workspace with unified file management, transcription, RAG tutoring, and study tools",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "test": "jest --config jest.config.js",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "education",
    "ai",
    "student",
    "workspace",
    "rag",
    "transcription"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "axios": "^1.12.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "mongoose": "^8.9.5",
    "multer": "^2.0.2",
    "openai": "^4.20.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.0.0"
  }
}
